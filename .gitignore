# --- Frontend (Next.js) ---
bynkbook-web/node_modules/
bynkbook-web/.next/
bynkbook-web/.env.local

# --- Infra (SST) ---
infra-sst/node_modules/
infra-sst/.sst/
infra-sst/.env
infra-sst/.env.*
!infra-sst/.env.example
infra-sst/**/*.pem
infra-sst/ca-secret
infra-sst/ca-secret.json
infra-sst/*secret*.json
infra-sst/sst-state-*
infra-sst/sst-deploy-debug
infra-sst/sst-deploy-debug*.txt
infra-sst/*deploy-debug*.txt
infra-sst/debug/
infra-sst/debug
infra-sst/debug.*
infra-sst/invoke-*
infra-sst/invoke*.json
infra-sst/*.out.json
infra-sst/out.json
infra-sst/payload.json
infra-sst/payload*.json
infra-sst/apigw*_test.json
infra-sst/cognito-*-auth.json
infra-sst/npm-install

# --- Generated metadata / logs / local backups ---
*.tsbuildinfo
*.log
*.bak
*.backup.*
*_backup_*
*.tmp
*.temp

# --- Local database scratch files ---
infra-sst/prisma/tmp_*.sql

# --- OS / Editor ---
.DS_Store
Thumbs.db
.vscode/

# --- Snapshots: never track secrets/certs ---
docs/snapshot_*/
docs/*snapshot*.zip
docs/**/.env
docs/**/ca-secret*.json
docs/**/*.pem
docs/**/cognito-*-auth.json
docs/**/invoke*.json
docs/**/apigw*.json
docs/**/payload*.json
docs/**/out*.json
docs/**/debug*
